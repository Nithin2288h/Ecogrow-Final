import os
os.environ['KERAS_BACKEND'] = 'tensorflow'  # Set backend before importing anything else
os.environ['TF_USE_LEGACY_KERAS'] = '1'     # Use TensorFlow's bundled Keras
os.environ['TF_CPP_MIN_LOG_LEVEL'] = '2'    # Reduce TF logging

import sys
from flask import Flask, render_template, request, redirect, send_from_directory, url_for
import numpy as np
import json
import uuid
import logging
import traceback
import psutil
import tensorflow as tf
from importlib.metadata import version, PackageNotFoundError

# Configure logging
logging.basicConfig(
    level=logging.DEBUG,
    format='%(asctime)s [%(levelname)s] %(message)s',
    stream=sys.stdout
)
logger = logging.getLogger(__name__)

app = Flask(__name__)
app.debug = True
logger.info("Initializing Flask application in debug mode...")

# Global variables
model = None
plant_disease = None


@app.errorhandler(Exception)
def handle_exception(e):
    logger.error(f"Unhandled exception: {str(e)}")
    logger.error(traceback.format_exc())
    return str(e), 500


def create_mock_model():
    """Create a mock model for testing when the real model can't be loaded"""
    logger.warning("Creating mock model for testing purposes")

    class MockModel:
        def predict(self, img):
            import random
            prediction = [0.0] * 39
            random_index = random.randint(0, 38)
            prediction[random_index] = 0.8 + random.random() * 0.2
            return [prediction]

    return MockModel()


def load_model_on_cpu():
    global model, plant_disease
    try:
        logger.info("Starting model loading process...")

        base_dir = os.path.dirname(os.path.abspath(__file__))
        model_path = os.path.join(base_dir, "models", "plant_disease_recog_model_pwp.keras")

        logger.info("Full model path: %s", model_path)

        if not os.path.exists(model_path):
            logger.error(f"Model file not found at {model_path}")
            model = create_mock_model()
        else:
            model_size = os.path.getsize(model_path)
            logger.info("Model file found (size: %.2f MB)", model_size / (1024 * 1024))

            process = psutil.Process()
            memory_before = process.memory_info().rss / 1024 / 1024
            logger.info("Memory before model load: %.2f MB", memory_before)

            logger.info("Loading model...")
            try:
                model = tf.keras.models.load_model(model_path, compile=False)
                logger.info("Real model loaded successfully!")
            except Exception as e:
                logger.error("Failed to load real model: %s", str(e))
                logger.warning("Using mock model for demonstration purposes")
                model = create_mock_model()

        # Load JSON mapping
        json_path = os.path.join(base_dir, "plant_disease.json")
        with open(json_path, 'r') as file:
            plant_disease = json.load(file)
            logger.info("Plant disease data loaded successfully")

        logger.info(f"TensorFlow version: {tf.__version__}")
        logger.info(f"Keras backend: {tf.keras.backend.backend()}")

    except Exception as e:
        logger.error("Error during initialization: %s", str(e))
        logger.error(traceback.format_exc())
        model = None
        return


# Flask routes
@app.route('/uploadimages/<path:filename>')
def uploaded_images(filename):
    upload_dir = os.path.join(os.getcwd(), 'uploadimages')
    return send_from_directory(upload_dir, filename)


@app.route('/homeguide')
def homeguide():
    return render_template('Crop Guidance/homeguid.html')


@app.route('/profit')
def profit():
    return render_template('Estimation Profit/profit.html')


@app.route('/fertilizers')
def fertilizers():
    return render_template('Fertilizers and Pesticides/fertilizer.html')


@app.route('/')
def home():
    return render_template('home.html')


@app.route('/weather')
def weather():
    return render_template('weather/weather.html')


@app.route('/guidance')
def guidance():
    return render_template('Crop Guidance/homeguid.html')


@app.route('/order')
def order():
    try:
        selected_type = request.args.get('type', '')
        return render_template('order.html', selected_type=selected_type)
    except Exception as e:
        logger.error(f"Error rendering order page: {str(e)}")
        return f"Error loading order page: {str(e)}", 500


@app.route('/guidance/<crop>')
def guidance_crop(crop):
    try:
        if '..' in crop or crop.startswith('/'):
            return "Invalid crop name", 400
        return render_template(f"Crop Guidance/{crop}.html")
    except Exception as e:
        logger.error(f"Error rendering {crop} guidance: {str(e)}")
        return f"Error loading {crop} guidance: {str(e)}", 404


def extract_features(image_path):
    image = tf.keras.utils.load_img(image_path, target_size=(160, 160))
    feature = tf.keras.utils.img_to_array(image)
    feature = np.expand_dims(feature, axis=0)
    return feature


def model_predict(image_path):
    img = extract_features(image_path)
    prediction = model.predict(img)
    prediction_index = np.argmax(prediction)
    confidence = float(np.max(prediction))

    disease_name = plant_disease[str(prediction_index)]

    prediction_data = {
        'name': disease_name,
        'confidence': f"{confidence * 100:.1f}%",
        'cause': get_disease_cause(disease_name),
        'cure': get_disease_cure(disease_name)
    }

    return prediction_data


