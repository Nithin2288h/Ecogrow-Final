@app.route('/upload/', methods=['POST', 'GET'])
def uploadimage():
    if request.method == "POST":
        logger.info("Received image upload request")

        if model is None:
            logger.error("Model not loaded. Cannot make predictions.")
            return render_template('home.html', error="Model not loaded. Please restart the server."), 500

        if 'img' not in request.files:
            return render_template('home.html', error="No image file selected."), 400

        image = request.files['img']

        if image.filename == '':
            return render_template('home.html', error="No image file selected."), 400

        allowed_extensions = {'.png', '.jpg', '.jpeg', '.gif', '.bmp'}
        file_ext = os.path.splitext(image.filename.lower())[1]
        if file_ext not in allowed_extensions:
            return render_template('home.html', error="Please upload a valid image file (PNG, JPG, JPEG, GIF, BMP)."), 400

        temp_name = f"uploadimages/temp_{uuid.uuid4().hex}_{image.filename}"
        temp_save_path = os.path.join(os.getcwd(), temp_name)

        try:
            os.makedirs(os.path.dirname(temp_save_path), exist_ok=True)
            image.save(temp_save_path)

            prediction = model_predict(temp_save_path)
            image_url_path = temp_name.replace(os.path.sep, '/')

            return render_template('home.html', result=True, imagepath=f'/{image_url_path}', prediction=prediction)

        except Exception as e:
            logger.error(f"Error during prediction: {str(e)}")
            logger.error(traceback.format_exc())
            return render_template('home.html', error=f"Error processing image: {str(e)}"), 500

    else:
        return redirect('/')


if __name__ == "__main__":
    logger.info("Starting Flask application...")
    try:
        upload_dir = os.path.join(os.getcwd(), 'uploadimages')
        if not os.path.exists(upload_dir):
            os.makedirs(upload_dir)

        load_model_on_cpu()

        app.run(host="127.0.0.1", port=5000, debug=True, use_reloader=False)
    except Exception as e:
        logger.error(f"Error starting Flask: {str(e)}", exc_info=True)
        sys.exit(1)
